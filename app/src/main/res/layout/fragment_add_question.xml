<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.AddQuestionFragment">


    <TextView
        android:id="@+id/TitleText"
        android:layout_width="340dp"
        android:layout_height="56dp"
        android:background="#EDE7F6"
        android:gravity="center_vertical|start"
        android:text="　タイトル："
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.486"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.217" />

    <TextView
        android:id="@+id/NextButton"
        android:layout_width="114dp"
        android:layout_height="52dp"
        android:background="#FFBBC6"
        android:gravity="center"
        android:text="公開する"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.882"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.887" />

    <ScrollView
        android:layout_width="336dp"
        android:layout_height="359dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.493"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.596">

        <LinearLayout
            android:id="@+id/QuestionLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/QuestionText"
                android:layout_width="336dp"
                android:layout_height="230dp"
                android:background="#EDE7F6"
                android:gravity="top|left"
                android:paddingTop="8dp"
                android:text="　Question："
                android:textSize="16sp" />

            <TextView
                android:id="@+id/CreatePlaceText"
                android:layout_width="336dp"
                android:layout_height="130dp"
                android:layout_marginTop="16dp"
                android:background="#EDE7F6"
                android:paddingTop="8dp"
                android:text="　作成場所：" />

            <LinearLayout
                android:id="@+id/ViewerLinearLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView6"
                    android:layout_width="135dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="#EDE7F6"
                    android:gravity="center_vertical|start"
                    android:text="　閲覧者制限：" />

                <Spinner
                    android:id="@+id/ViewerSpinner"
                    android:layout_width="201dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/spinner_fragment_background" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/AnswerLinearLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView7"
                    android:layout_width="135dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="#EDE7F6"
                    android:gravity="center_vertical|start"
                    android:text="　回答者制限：" />

                <Spinner
                    android:id="@+id/AnswerSpinner"
                    android:layout_width="201dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/spinner_fragment_background" />
            </LinearLayout>

            <TextView
                android:id="@+id/TagText"
                android:layout_width="336dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="#EDE7F6"
                android:gravity="center_vertical|start"
                android:text="　タグ：" />

        </LinearLayout>

    </ScrollView>

    <TextView
        android:id="@+id/ExplanationText"
        android:layout_width="150dp"
        android:layout_height="35dp"
        android:text="閲覧者制限、回答者制限を選択してください"
        android:textSize="12sp"
        android:textColor="#D50000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.186"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.877" />


</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.RegisterActivity">
    <TextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="はじめに"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#D9D9D9"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <TextView
        android:id="@+id/description"
        android:layout_width="300dp"
        android:layout_height="100dp"
        android:text="あなたの　　　　　　　　　　　　　　\n大学・学部・学科・学年を\n　　　　　　　　　　入力してください"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#D9D9D9"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <Spinner
        android:id="@+id/universitySpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"/>

    <Spinner
        android:id="@+id/facultySpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/universitySpinner"
        app:layout_constraintStart_toStartOf="@id/universitySpinner"
        app:layout_constraintEnd_toEndOf="@id/universitySpinner"
        android:layout_marginTop="16dp"/>

    <Spinner
        android:id="@+id/departmentSpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/facultySpinner"
        app:layout_constraintStart_toStartOf="@id/universitySpinner"
        app:layout_constraintEnd_toEndOf="@id/universitySpinner"
        android:layout_marginTop="16dp"/>

    <Spinner
        android:id="@+id/gradeSpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="@id/universitySpinner"
        app:layout_constraintStart_toStartOf="@id/universitySpinner"
        app:layout_constraintTop_toBottomOf="@id/departmentSpinner" />

    <Button
        android:id="@+id/confirmButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="確定する"
        app:layout_constraintTop_toBottomOf="@id/gradeSpinner"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp"/>
    <include layout="@layout/navigation"/>

</androidx.constraintlayout.widget.ConstraintLayout>
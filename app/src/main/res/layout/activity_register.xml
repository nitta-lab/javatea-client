<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.RegisterActivity">
    <include
        android:id="@+id/modeBar"
        layout="@layout/activity_mode_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/description"
        android:layout_width="300dp"
        android:layout_height="150dp"
        android:text="あなたの　　　　　　　　　　　　　　\n大学・学部・学科・学年を\n　　　　　　　　　　入力してください"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#D9D9D9"
        app:layout_constraintTop_toBottomOf="@id/modeBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <LinearLayout
        android:id="@+id/universityRow"
        android:layout_width="300dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#D9D9D9"

        app:layout_constraintTop_toBottomOf="@id/description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="大学"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/universityText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="選択してください"
            android:gravity="center_vertical"/>

        <TextView
            android:id="@+id/universityPullDownText"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:text="▼"
            android:gravity="center"/>

    </LinearLayout>
    <LinearLayout
        android:id="@+id/facultyRow"
        android:layout_width="300dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#D9D9D9"

        app:layout_constraintTop_toBottomOf="@+id/universityRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="学部"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/facultyText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="選択してください"
            android:gravity="center_vertical"/>

        <TextView
            android:id="@+id/facultyPullDownText"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:text="▼"
            android:gravity="center"/>

    </LinearLayout>
    <LinearLayout
        android:id="@+id/departmentRow"
        android:layout_width="300dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#D9D9D9"

        app:layout_constraintTop_toBottomOf="@id/facultyRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="学科"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/departmentText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="選択してください"
            android:gravity="center_vertical"/>

        <TextView
            android:id="@+id/departmentPullDownText"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:text="▼"
            android:gravity="center"/>

    </LinearLayout>
    <LinearLayout
        android:id="@+id/gradeRow"
        android:layout_width="300dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#D9D9D9"

        app:layout_constraintTop_toBottomOf="@id/departmentRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="学年"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/gradeText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="選択してください"
            android:gravity="center_vertical"/>

        <TextView
            android:id="@+id/gradePullDownText"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:text="▼"
            android:gravity="center"/>

    </LinearLayout>

    <Button
        android:id="@+id/fixButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="修正する"
        app:layout_constraintTop_toBottomOf="@id/gradeRow"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="24dp"/>

    <Button
        android:id="@+id/confirmButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="確定する"
        app:layout_constraintTop_toBottomOf="@id/gradeRow"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp"/>
    <!--    <include layout="@layout/navigation"/>-->

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.AddAnswerFragment">

    <TextView
        android:id="@+id/QuestionTitle"
        android:layout_width="341dp"
        android:layout_height="wrap_content"
        android:background="#FFE6E0E9"
        android:text="Question："
        android:textColor="#000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.143" />

    <ScrollView
        android:layout_width="341dp"
        android:layout_height="wrap_content"
        android:background="#FFE6E0E9"
        app:layout_constraintEnd_toEndOf="@id/QuestionTitle"
        app:layout_constraintStart_toStartOf="@id/QuestionTitle"
        app:layout_constraintTop_toBottomOf="@id/QuestionTitle"
        app:layout_constraintVertical_bias="0.346">

        <TextView
            android:id="@+id/QuestionBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFE6E0E9"
            android:text="テストテストテストテストテストテストテストテストテストテストテストテスト"
            android:textColor="#000000"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteY="75dp" />
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
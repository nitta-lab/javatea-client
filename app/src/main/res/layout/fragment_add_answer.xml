<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.AddAnswerFragment">

    <TextView
        android:id="@+id/QuestionTitle"
        android:layout_width="341dp"
        android:layout_height="wrap_content"
        android:background="#FFE6E0E9"
        android:text="Question："
        android:textColor="#000000"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.025" />

    <ScrollView
        android:id="@+id/QuestionFrame"
        android:layout_width="341dp"
        android:layout_height="125dp"
        android:background="#FFE6E0E9"
        app:layout_constraintEnd_toEndOf="@id/QuestionTitle"
        app:layout_constraintStart_toStartOf="@id/QuestionTitle"
        app:layout_constraintTop_toBottomOf="@id/QuestionTitle"
        app:layout_constraintVertical_bias="0.346">

        <TextView
            android:id="@+id/QuestionBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFE6E0E9"
            android:text="テストテストテストテストテストテストテストテストテストテストテストテスト"
            android:textColor="#000000"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteY="75dp" />
    </ScrollView>

    <TextView
        android:id="@+id/AnswerTitle"
        android:layout_width="341dp"
        android:layout_height="wrap_content"
        android:background="#FFE6E0E9"
        android:text="あなたの解答："
        android:textColor="#000000"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/QuestionFrame"
        app:layout_constraintVertical_bias="0.02" />

    <ScrollView
        android:id="@+id/AnswerFrame"
        android:layout_width="341dp"
        android:layout_height="295dp"
        android:background="#FFE6E0E9"
        app:layout_constraintEnd_toEndOf="@id/AnswerTitle"
        app:layout_constraintStart_toStartOf="@id/AnswerTitle"
        app:layout_constraintTop_toBottomOf="@id/AnswerTitle"
        app:layout_constraintVertical_bias="0.346">

        <EditText
            android:id="@+id/AnswerBody"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFE6E0E9"
            android:textColor="#000000"
            android:textSize="14sp"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteY="75dp" />
    </ScrollView>

    <Button
        android:id="@+id/login_button"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#FFE8E8"
        android:paddingVertical="9dp"
        android:text="次へ"
        android:textColor="#000000"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/AnswerFrame"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/AnswerFrame"
        app:layout_constraintVertical_bias="0.165"
        app:rippleColor="@color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>